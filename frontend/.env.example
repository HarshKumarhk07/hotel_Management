# Public base URL of the KDS backend API (include the /api/v1 prefix).
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Google OAuth client id (for "Sign in with Google" — added in the auth phase).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Razorpay public key id (checkout widget — added in the payment phase).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Sentry error monitoring (optional) ───────────────────────────────────────
# Leave blank to disable. When NEXT_PUBLIC_SENTRY_DSN is set, the build wraps
# with Sentry and browser/server errors are captured.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=
# Source-map upload (build only — set in your deploy/CI environment, not here):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
