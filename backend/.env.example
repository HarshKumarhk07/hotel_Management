# ─────────────────────────────────────────────────────────────────────────────
#  KDS BACKEND — ENVIRONMENT TEMPLATE
#  Copy to `.env` and fill real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Public URLs (used in email links + CORS)
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
# Comma-separated allowlist. NO wildcards in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/kds?retryWrites=true&w=majority

# ── JWT / Sessions ───────────────────────────────────────────────────────────
# Generate strong secrets:  openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
# Used to sign cookies
COOKIE_SECRET=change-me-cookie-secret-min-32-chars

# ── Privileged access gates ──────────────────────────────────────────────────
# Required as an extra factor when an ADMIN or KITCHEN account logs in.
ADMIN_SECRET_CODE=change-me-admin-secret-code
KITCHEN_SECRET_CODE=change-me-kitchen-secret-code

# Account lockout
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=2

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Brevo (email) ────────────────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM_NAME=Hotel Kitchen
EMAIL_FROM_ADDRESS=no-reply@yourhotel.com
SECURITY_ALERT_EMAIL=security@yourhotel.com

# ── Razorpay (added in payments phase) ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary (added in menu phase) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Error monitoring (Sentry) ────────────────────────────────────────────────
# Leave blank to disable. When set, unhandled 5xx errors are reported.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Data retention (TTL purge of high-volume collections, in days) ───────────
AUDIT_LOG_RETENTION_DAYS=365
NOTIFICATION_RETENTION_DAYS=90

# ── API docs (Swagger) ───────────────────────────────────────────────────────
# In production, /docs is exposed ONLY if BOTH are set (HTTP Basic auth).
# Leave blank in production to hide the API docs entirely.
SWAGGER_USER=
SWAGGER_PASSWORD=
